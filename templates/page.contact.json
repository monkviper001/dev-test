            "padding-inline-end": 0
          },
          "blocks": {
            "row_1": {
              "type": "_accordion-row",
              "settings": {
                "heading": "What are your business hours?"
              },
              "blocks": {
                "row_1_text": {
                  "type": "text",
                  "settings": {
                    "text": "<p>Our team is available Monday through Friday, 9:00 AM to 5:00 PM EST. We aim to respond to all inquiries within 24 hours.</p>",
                    "type_preset": "rte",
                    "font": "var(--font-body--family)",
                    "font_size": "",
                    "line_height": "normal",
                    "letter_spacing": "normal",
                    "case": "none",
                    "wrap": "pretty",
                    "width": "100%",
                    "max_width": "normal",
                    "alignment": "left",
                    "color": "",
                    "background": false,
                    "background_color": "#00000026",
                    "corner_radius": 0,
                    "padding-block-start": 0,
                    "padding-block-end": 0,
                    "padding-inline-start": 0,
                    "padding-inline-end": 0
                  }
                }
              },
              "block_order": [
                "row_1_text"
              ]
            },
            "row_2": {
              "type": "_accordion-row",
              "settings": {
                "heading": "How can I track my order?"
              },
              "blocks": {
                "row_2_text": {
                  "type": "text",
                  "settings": {
                    "text": "<p>Once your order has shipped, you will receive a confirmation email with a tracking number. You can use this number on our website to check the status of your delivery.</p>",
                    "type_preset": "rte",
                    "font": "var(--font-body--family)",
                    "font_size": "",
                    "line_height": "normal",
                    "letter_spacing": "normal",
                    "case": "none",
                    "wrap": "pretty",
                    "width": "100%",
                    "max_width": "normal",
                    "alignment": "left",
                    "color": "",
                    "background": false,
                    "background_color": "#00000026",
                    "corner_radius": 0,
                    "padding-block-start": 0,
                    "padding-block-end": 0,
                    "padding-inline-start": 0,
                    "padding-inline-end": 0
                  }
                }
              },
              "block_order": [
                "row_2_text"
              ]
            },
            "row_3": {
              "type": "_accordion-row",
              "settings": {
                "heading": "What is your return policy?"
              },
              "blocks": {
                "row_3_text": {
                  "type": "text",
                  "settings": {
                    "text": "<p>We offer a 30-day return policy on all items. Products must be in their original condition and packaging. Please contact our support team to initiate a return.</p>",
                    "type_preset": "rte",
                    "font": "var(--font-body--family)",
                    "font_size": "",
                    "line_height": "normal",
                    "letter_spacing": "normal",
                    "case": "none",
                    "wrap": "pretty",
                    "width": "100%",
                    "max_width": "normal",
                    "alignment": "left",
                    "color": "",
                    "background": false,
                    "background_color": "#00000026",
                    "corner_radius": 0,
                    "padding-block-start": 0,
                    "padding-block-end": 0,
                    "padding-inline-start": 0,
                    "padding-inline-end": 0
                  }
                }
              },
              "block_order": [
                "row_3_text"
              ]
            },
            "row_4": {
              "type": "_accordion-row",
              "settings": {
                "heading": "Do you offer international shipping?"
              },
              "blocks": {
                "row_4_text": {
                  "type": "text",
                  "settings": {
                    "text": "<p>Yes, we ship to most countries worldwide. Shipping rates and delivery times vary by location. You can see estimated costs at checkout.</p>",
                    "type_preset": "rte",
                    "font": "var(--font-body--family)",
                    "font_size": "",
                    "line_height": "normal",
                    "letter_spacing": "normal",
                    "case": "none",
