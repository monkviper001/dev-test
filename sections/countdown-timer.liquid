{%- liquid
  assign section_id = 'CountdownTimer-' | append: section.id
  assign target_date = section.settings.target_date
  assign hide_when_expired = section.settings.hide_when_expired
-%}

{%- capture children -%}
  {%- content_for 'blocks' -%}
{%- endcapture -%}

<countdown-timer
  data-target-date="{{ target_date }}"
  {% if hide_when_expired %}data-hide-when-expired{% endif %}
>
  <div class="section-background color-{{ section.settings.color_scheme }}"></div>
  <section
    id="{{ section_id }}"
    class="countdown-timer section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
    style="
      --countdown-direction: {{ section.settings.content_direction }};
      --countdown-gap: {{ section.settings.gap }}px;
      --countdown-halign: {{ section.settings.horizontal_alignment }};
      --countdown-valign: {{ section.settings.vertical_alignment }};
      padding-block-start: {{ section.settings.padding-block-start }}px;
      padding-block-end: {{ section.settings.padding-block-end }}px;
    "
  >
    {{ children }}

    <div class="countdown-timer__display" ref="display" aria-live="polite" aria-atomic="true">
      <div class="countdown-timer__unit">
        <span class="countdown-timer__value" ref="days">--</span>
        <span class="countdown-timer__label">{{ section.settings.date_label | escape }}</span>
      </div>
      <div class="countdown-timer__separator" aria-hidden="true">:</div>
      <div class="countdown-timer__unit">
        <span class="countdown-timer__value" ref="hours">--</span>
        <span class="countdown-timer__label">{{ section.settings.hours_label | escape }}</span>
      </div>
      <div class="countdown-timer__separator" aria-hidden="true">:</div>
      <div class="countdown-timer__unit">
        <span class="countdown-timer__value" ref="minutes">--</span>
        <span class="countdown-timer__label">{{ section.settings.minutes_label | escape }}</span>
      </div>
      <div class="countdown-timer__separator" aria-hidden="true">:</div>
      <div class="countdown-timer__unit">
        <span class="countdown-timer__value" ref="seconds">--</span>
        <span class="countdown-timer__label">{{ section.settings.seconds_label | escape }}</span>
      </div>
    </div>

    <p class="countdown-timer__expired" ref="expiredMessage" hidden>
      {{ section.settings.expired_message | escape }}
    </p>
  </section>
</countdown-timer>

{% stylesheet %}
  countdown-timer {
    display: block;
    position: relative;
  }

  .countdown-timer {
    display: flex;
    flex-direction: var(--countdown-direction, column);
    align-items: var(--countdown-halign, center);
    justify-content: var(--countdown-valign, center);
    gap: var(--countdown-gap, 12px);
  }

  .countdown-timer__display {
    display: flex;
    align-items: center;
    gap: var(--gap-sm);
    flex-wrap: wrap;
    justify-content: center;
  }

  .countdown-timer__unit {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--gap-2xs);
    min-width: 4rem;
    padding: var(--padding-sm) var(--padding-lg);
    border-radius: var(--style-border-radius-sm);
    background: rgb(var(--color-foreground-rgb) / var(--opacity-5-15));
  }

  .countdown-timer__value {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight, 700);
    font-size: var(--font-size--3xl);
    line-height: var(--line-height--display-tight);
    color: var(--color-foreground-heading);
    font-variant-numeric: tabular-nums;
  }

  .countdown-timer__label {
    font-family: var(--font-body--family);
    font-size: var(--font-size--xs);
    line-height: var(--line-height--body-normal);
    color: rgb(var(--color-foreground-rgb) / var(--opacity-40-60));
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .countdown-timer__separator {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight, 700);
    font-size: var(--font-size--2xl);
    line-height: var(--line-height--display-tight);
    color: var(--color-foreground-heading);
    padding-block-end: var(--padding-xl);
  }

  .countdown-timer__expired {
    font-family: var(--font-heading--family);
    font-size: var(--font-size--lg);
    line-height: var(--line-height--heading-normal);
    color: var(--color-foreground-heading);
    text-align: center;
    margin: 0;
  }

  @media screen and (min-width: 768px) {
    .countdown-timer__unit {
      min-width: 5.5rem;
      padding: var(--padding-lg) var(--padding-xl);
    }

    .countdown-timer__value {
      font-size: var(--font-size--4xl);
    }

    .countdown-timer__separator {
      font-size: var(--font-size--3xl);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .countdown-timer__value {
      transition: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  import { Component } from '@theme/component';

  class CountdownTimer extends Component {
    #intervalId = null;

    connectedCallback() {
      super.connectedCallback();
      this.#startCountdown();
    }

    disconnectedCallback() {
      super.disconnectedCallback();
      this.#stopCountdown();
    }

    #startCountdown() {
      this.#update();
      this.#intervalId = setInterval(() => this.#update(), 1000);
    }

    #stopCountdown() {
      if (this.#intervalId) {
        clearInterval(this.#intervalId);
        this.#intervalId = null;
      }
    }

    #update() {
      const targetDate = this.dataset.targetDate;
      if (!targetDate) return;

      const target = new Date(targetDate).getTime();
      const now = Date.now();
      const diff = target - now;

      if (diff <= 0) {
        this.#handleExpired();
        return;
      }

      const days = Math.floor(diff / (1000 * 60 * 60 * 24));
      const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
      const seconds = Math.floor((diff % (1000 * 60)) / 1000);

      this.refs.days.textContent = String(days).padStart(2, '0');
      this.refs.hours.textContent = String(hours).padStart(2, '0');
      this.refs.minutes.textContent = String(minutes).padStart(2, '0');
      this.refs.seconds.textContent = String(seconds).padStart(2, '0');
    }

    #handleExpired() {
      this.#stopCountdown();

      if (this.refs.display) {
        this.refs.display.hidden = true;
      }

      if (this.refs.expiredMessage) {
        this.refs.expiredMessage.hidden = false;
      }

      if (this.hasAttribute('data-hide-when-expired')) {
        this.hidden = true;
      }
    }
  }

  customElements.define('countdown-timer', CountdownTimer);
{% endjavascript %}

{% schema %}
{
