{%- liquid
  assign heading = section.settings.heading
  assign heading_tag = section.settings.heading_tag
  assign max_products = section.settings.max_products
  assign badge_text = section.settings.badge_text
  assign badge_tag = section.settings.badge_tag
  assign button_label = section.settings.button_label
  assign shop_all_label = section.settings.shop_all_label
-%}

{%- render 'font-cubano' -%}

<bestsellers-tabs>
  <div class="section-background color-{{ section.settings.color_scheme }}"></div>
  <section
    id="BestsellersTabs-{{ section.id }}"
    class="bestsellers-tabs section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
    style="
      padding-block-start: {{ section.settings.padding-block-start }}px;
      padding-block-end: {{ section.settings.padding-block-end }}px;
      --bt-columns: {{ section.settings.columns }};
      --bt-columns-mobile: {{ section.settings.mobile_columns }};
      --bt-gap: 16px;
    "
  >
    <div class="bestsellers-tabs__header">
      {%- if heading != blank -%}
        <{{ heading_tag }} class="bestsellers-tabs__heading">
          {{- heading | escape -}}
        </{{ heading_tag }}>
      {%- endif -%}

      {%- if section.settings.icons_style != 'none' -%}
        <div class="bestsellers-tabs__nav-arrows">
          <button
            class="bestsellers-tabs__arrow{% if section.settings.icons_shape != 'none' %} bestsellers-tabs__arrow--{{ section.settings.icons_shape }}{% endif %}"
            type="button"
            aria-label="{{ 'sections.bestsellers_tabs.scroll_left' | t }}"
            data-direction="prev"
          >
            {%- render 'icon-chevron-left' -%}
          </button>
          <button
            class="bestsellers-tabs__arrow{% if section.settings.icons_shape != 'none' %} bestsellers-tabs__arrow--{{ section.settings.icons_shape }}{% endif %}"
            type="button"
            aria-label="{{ 'sections.bestsellers_tabs.scroll_right' | t }}"
            data-direction="next"
          >
            {%- render 'icon-chevron-right' -%}
          </button>
        </div>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="bestsellers-tabs__controls">
        <div
          class="bestsellers-tabs__tabs"
          role="tablist"
          aria-label="{{ 'sections.bestsellers_tabs.tab_navigation' | t }}"
        >
          {%- for block in section.blocks -%}
            <button
              class="bestsellers-tabs__tab{% if forloop.first %} bestsellers-tabs__tab--active{% endif %}"
              role="tab"
              id="BestTab-{{ section.id }}-{{ forloop.index }}"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              aria-controls="BestPanel-{{ section.id }}-{{ forloop.index }}"
              tabindex="{% if forloop.first %}0{% else %}-1{% endif %}"
              data-collection-url="{{ block.settings.collection.url | default: '#' }}"
            >
              {{- block.settings.tab_label | escape -}}
            </button>
          {%- endfor -%}
        </div>

        {%- if shop_all_label != blank -%}
          {%- assign first_block = section.blocks | first -%}
          <a
            class="bestsellers-tabs__shop-all"
            href="{{ first_block.settings.collection.url | default: '/collections/all' }}"
            data-shop-all-link
          >
            {{- shop_all_label | escape -}}
          </a>
        {%- endif -%}
      </div>

      <div class="bestsellers-tabs__panels">
        {%- for block in section.blocks -%}
          <div
            class="bestsellers-tabs__panel{% if forloop.first %} bestsellers-tabs__panel--active{% endif %}"
            role="tabpanel"
            id="BestPanel-{{ section.id }}-{{ forloop.index }}"
            aria-labelledby="BestTab-{{ section.id }}-{{ forloop.index }}"
            {% unless forloop.first %}hidden{% endunless %}
            {{ block.shopify_attributes }}
          >
            <div class="bestsellers-tabs__carousel">
              {%- if block.settings.collection != blank -%}
                {%- for product in block.settings.collection.products limit: max_products -%}
                  {%- liquid
                    assign show_badge = false
                    if badge_text != blank
                      if badge_tag == blank
                        assign show_badge = true
                      elsif product.tags contains badge_tag
                        assign show_badge = true
                      endif
                    endif
                    assign variant = product.selected_or_first_available_variant
                  -%}

                  <article class="bestsellers-tabs__card">
                    <a href="{{ product.url }}" class="bestsellers-tabs__card-media" tabindex="-1" aria-hidden="true">
                      {%- if product.featured_image != blank -%}
                        {{
                          product.featured_image
                          | image_url: width: 600
                          | image_tag:
                            class: 'bestsellers-tabs__img',
                            sizes: '(min-width: 992px) 20vw, (min-width: 768px) 33vw, 60vw',
                            widths: '200, 300, 400, 500, 600',
                            loading: 'lazy',
                            alt: product.title
                        }}
                      {%- else -%}
                        <div class="bestsellers-tabs__placeholder">
                          {{ 'product-1' | placeholder_svg_tag: 'bestsellers-tabs__placeholder-svg' }}
                        </div>
                      {%- endif -%}

                      {%- if show_badge -%}
                        <span class="bestsellers-tabs__badge" style="background-color: {{ section.settings.badge_color }};">
                          {{- badge_text | escape -}}
                        </span>
                      {%- endif -%}
                    </a>

                    <div class="bestsellers-tabs__card-body">
                      <div class="bestsellers-tabs__card-info">
                        <a href="{{ product.url }}" class="bestsellers-tabs__card-link">
                          <h3 class="bestsellers-tabs__card-title">
                            {{- product.title | escape -}}
                          </h3>
                        </a>

                        {%- if product.vendor != blank -%}
                          <p class="bestsellers-tabs__card-vendor">
                            {{- product.vendor | escape -}}
                          </p>
                        {%- endif -%}

                        {%- if variant.title != blank and variant.title != 'Default Title' -%}
                          <p class="bestsellers-tabs__card-variant">
                            {{- variant.title | escape -}}
                          </p>
                        {%- endif -%}
                      </div>

                      <div class="bestsellers-tabs__card-footer">
                        <span class="bestsellers-tabs__card-price">
                          {{- product.price | money -}}
                        </span>

                        {%- if product.available -%}
                          {%- form 'product', product, class: 'bestsellers-tabs__add-form' -%}
                            <input type="hidden" name="id" value="{{ variant.id }}">
                            <button type="submit" class="bestsellers-tabs__add-btn">
                              {{- button_label | escape -}}
                            </button>
                          {%- endform -%}
                        {%- else -%}
                          <span class="bestsellers-tabs__sold-out">
                            {{- 'products.product.sold_out' | t -}}
                          </span>
                        {%- endif -%}
                      </div>
                    </div>
                  </article>
                {%- endfor -%}
              {%- else -%}
                {%- for i in (1..max_products) -%}
                  <article class="bestsellers-tabs__card">
                    <div class="bestsellers-tabs__card-media">
                      <div class="bestsellers-tabs__placeholder">
                        {{ 'product-1' | placeholder_svg_tag: 'bestsellers-tabs__placeholder-svg' }}
                      </div>
                      {%- if badge_text != blank -%}
                        <span class="bestsellers-tabs__badge" style="background-color: {{ section.settings.badge_color }};">
                          {{- badge_text | escape -}}
                        </span>
                      {%- endif -%}
                    </div>
                    <div class="bestsellers-tabs__card-body">
                      <div class="bestsellers-tabs__card-info">
                        <h3 class="bestsellers-tabs__card-title">{{ 'content.product_placeholder' | t }}</h3>
                      </div>
                      <div class="bestsellers-tabs__card-footer">
                        <span class="bestsellers-tabs__card-price">{{ 0 | money }}</span>
                      </div>
                    </div>
                  </article>
                {%- endfor -%}
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </section>
</bestsellers-tabs>

{% stylesheet %}
  bestsellers-tabs {
    display: block;
    position: relative;
  }

  .bestsellers-tabs {
    display: flex;
    flex-direction: column;
    gap: var(--gap-xl);
  }

  /* Header: heading + navigation arrows */
  .bestsellers-tabs__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--gap-lg);
  }

  .bestsellers-tabs__heading {
    font-family: 'Cubano', var(--font-heading--family);
    font-size: var(--font-size--xl);
    font-weight: 400;
    line-height: var(--line-height--heading-tight);
    text-transform: uppercase;
    color: var(--color-foreground);
    margin: 0;
  }

  @media screen and (min-width: 768px) {
    .bestsellers-tabs__heading {
      font-size: var(--font-size--2xl);
    }
  }

  @media screen and (min-width: 992px) {
    .bestsellers-tabs__heading {
      font-size: var(--font-size--3xl);
    }
  }

  .bestsellers-tabs__nav-arrows {
    display: flex;
    align-items: center;
    gap: var(--gap-2xs);
    flex-shrink: 0;
  }

  .bestsellers-tabs__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    min-height: var(--minimum-touch-target);
    min-width: var(--minimum-touch-target);
    color: var(--color-foreground);
  }

  .bestsellers-tabs__arrow--circle {
    border-radius: 50%;
    background: rgb(var(--color-foreground-rgb) / 0.06);
  }

  .bestsellers-tabs__arrow--square {
    border-radius: var(--style-border-radius-xs);
    background: rgb(var(--color-foreground-rgb) / 0.06);
  }

  .bestsellers-tabs__arrow:focus-visible {
    outline: var(--focus-outline-width) solid var(--color-foreground);
    outline-offset: var(--focus-outline-offset);
  }

  .bestsellers-tabs__arrow svg {
    width: 32px;
    height: 32px;
  }

  /* Controls: tabs + shop all button */
  .bestsellers-tabs__controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--gap-xl);
    flex-wrap: wrap;
  }

  .bestsellers-tabs__tabs {
    display: flex;
    gap: var(--gap-xl);
    flex-wrap: wrap;
  }

  .bestsellers-tabs__tab {
    font-family: var(--font-body--family);
    font-size: var(--font-size--sm);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-foreground);
    background: none;
    border: none;
    border-block-end: 2px solid transparent;
    padding-block: var(--padding-xs);
    padding-inline: 0;
    cursor: pointer;
    transition: border-color var(--animation-speed) var(--animation-easing);
    min-height: var(--minimum-touch-target);
    white-space: nowrap;
  }

  .bestsellers-tabs__tab:hover {
    border-block-end-color: rgb(var(--color-foreground-rgb) / var(--opacity-35-55));
  }

  .bestsellers-tabs__tab--active {
    font-weight: 700;
    border-block-end-color: var(--color-foreground);
  }

  .bestsellers-tabs__tab:focus-visible {
    outline: var(--focus-outline-width) solid var(--color-foreground);
    outline-offset: var(--focus-outline-offset);
  }

  .bestsellers-tabs__shop-all {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary-button-background);
    color: var(--color-primary-button-text);
    border: 1px solid var(--color-primary-button-border);
    border-radius: var(--style-border-radius-buttons-primary, 4px);
    padding: var(--padding-sm) var(--padding-2xl);
    font-family: var(--font-body--family);
    font-size: var(--font-size--3xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    white-space: nowrap;
    transition: background var(--animation-speed) var(--animation-easing),
                color var(--animation-speed) var(--animation-easing);
    min-height: var(--minimum-touch-target);
    flex-shrink: 0;
  }

  .bestsellers-tabs__shop-all:hover {
    background: var(--color-primary-button-hover-background);
    color: var(--color-primary-button-hover-text);
    border-color: var(--color-primary-button-hover-border);
  }

  .bestsellers-tabs__shop-all:focus-visible {
    outline: var(--focus-outline-width) solid var(--color-foreground);
    outline-offset: var(--focus-outline-offset);
  }

  /* Tab panels */
  .bestsellers-tabs__panels {
    width: 100%;
  }

  .bestsellers-tabs__panel:not(.bestsellers-tabs__panel--active) {
    display: none;
  }

  .bestsellers-tabs__panel--active {
    display: block;
  }

  /* Carousel */
  .bestsellers-tabs__carousel {
    display: flex;
    gap: var(--bt-gap, 16px);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .bestsellers-tabs__carousel::-webkit-scrollbar {
    display: none;
  }

  /* Product cards */
  .bestsellers-tabs__card {
    flex: 0 0 auto;
    width: calc((100% - (var(--bt-columns) - 1) * var(--bt-gap, 16px)) / var(--bt-columns));
    display: flex;
    flex-direction: column;
    scroll-snap-align: start;
    background: var(--color-background);
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.08);
    border-radius: var(--style-border-radius-sm);
    overflow: hidden;
    min-width: 200px;
  }

  @media screen and (max-width: 749px) {
    .bestsellers-tabs__card {
      width: calc((100% - (var(--bt-columns-mobile) - 1) * var(--bt-gap, 16px)) / var(--bt-columns-mobile));
      min-width: 160px;
    }
  }

  .bestsellers-tabs__card-media {
    position: relative;
    display: block;
    aspect-ratio: 5 / 6;
    background: rgb(var(--color-foreground-rgb) / 0.04);
    overflow: hidden;
    text-decoration: none;
  }

  .bestsellers-tabs__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .bestsellers-tabs__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    background: rgb(var(--color-foreground-rgb) / 0.04);
  }

  .bestsellers-tabs__placeholder-svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .bestsellers-tabs__badge {
    position: absolute;
    inset-block-start: var(--padding-sm);
    inset-inline-start: var(--padding-sm);
    display: inline-block;
    padding: var(--padding-3xs) var(--padding-xs);
    font-family: var(--font-body--family);
    font-size: var(--font-size--3xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #fff;
    line-height: 1.4;
    border-radius: 2px;
  }

  /* Card body */
  .bestsellers-tabs__card-body {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    padding: var(--padding-lg);
    gap: var(--gap-sm);
  }

  .bestsellers-tabs__card-info {
    display: flex;
    flex-direction: column;
    gap: var(--gap-3xs);
    flex-grow: 1;
  }

  .bestsellers-tabs__card-link {
    text-decoration: none;
    color: inherit;
  }

  .bestsellers-tabs__card-link:hover .bestsellers-tabs__card-title {
    text-decoration: underline;
  }

  .bestsellers-tabs__card-title {
    font-family: 'Cubano', var(--font-heading--family);
    font-size: var(--font-size--sm);
    font-weight: 400;
    line-height: var(--line-height--heading-normal);
    text-transform: uppercase;
    color: var(--color-foreground);
    margin: 0;
  }

  .bestsellers-tabs__card-vendor {
    font-family: var(--font-body--family);
    font-size: var(--font-size--2xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary);
    margin: 0;
  }

  .bestsellers-tabs__card-variant {
    font-family: var(--font-body--family);
    font-size: var(--font-size--xs);
    color: var(--color-foreground);
    margin: 0;
  }

  /* Card footer: price + add button */
  .bestsellers-tabs__card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--gap-sm);
    margin-block-start: auto;
    padding-block-start: var(--padding-sm);
  }

  .bestsellers-tabs__card-price {
    font-family: var(--font-heading--family);
    font-size: var(--font-size--lg);
    font-weight: 700;
    color: var(--color-foreground);
    white-space: nowrap;
  }

  .bestsellers-tabs__add-form {
    flex-shrink: 0;
  }

  .bestsellers-tabs__add-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-background);
    color: var(--color-foreground);
    border: 1px solid var(--color-foreground);
    border-radius: var(--style-border-radius-buttons-secondary, 4px);
    padding: var(--padding-xs) var(--padding-lg);
    font-family: var(--font-body--family);
    font-size: var(--font-size--3xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    white-space: nowrap;
    transition: background var(--animation-speed) var(--animation-easing),
                color var(--animation-speed) var(--animation-easing);
    min-height: 36px;
  }

  .bestsellers-tabs__add-btn:hover {
    background: var(--color-foreground);
    color: var(--color-background);
  }

  .bestsellers-tabs__add-btn:focus-visible {
    outline: var(--focus-outline-width) solid var(--color-foreground);
    outline-offset: var(--focus-outline-offset);
  }

  .bestsellers-tabs__sold-out {
    font-family: var(--font-body--family);
    font-size: var(--font-size--xs);
    color: rgb(var(--color-foreground-rgb) / 0.5);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Mobile adjustments */
  @media screen and (max-width: 749px) {
    .bestsellers-tabs__controls {
      flex-direction: column;
      align-items: flex-start;
    }

    .bestsellers-tabs__tabs {
      gap: var(--gap-lg);
    }

    .bestsellers-tabs__shop-all {
      align-self: flex-start;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .bestsellers-tabs__tab,
    .bestsellers-tabs__shop-all,
    .bestsellers-tabs__add-btn {
      transition: none;
    }

    .bestsellers-tabs__carousel {
      scroll-behavior: auto;
    }
  }
{% endstylesheet %}

<script src="{{ 'bestsellers-tabs.js' | asset_url }}" type="module"></script>

{% schema %}
{
  "name": "t:names.bestsellers_tabs",
  "tag": "div",
  "class": "bestsellers-tabs-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:settings.heading",
      "default": "Our Bestsellers"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:settings.heading_tag",
      "options": [
        { "value": "h2", "label": "t:options.h2" },
        { "value": "h3", "label": "t:options.h3" },
        { "value": "h4", "label": "t:options.h4" }
      ],
      "default": "h2"
    },
    {
      "type": "text",
      "id": "shop_all_label",
      "label": "t:sections.bestsellers_tabs.settings.shop_all_label.label",
      "default": "Shop All Bestsellers"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "t:settings.product_count",
      "min": 1,
      "max": 16,
      "step": 1,
      "default": 8
    },
    {
      "type": "header",
      "content": "t:content.grid"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "t:settings.columns",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 5
    },
    {
      "type": "select",
      "id": "mobile_columns",
      "label": "t:settings.mobile_columns",
      "options": [
        { "value": "1", "label": "t:options.one_number" },
        { "value": "2", "label": "t:options.two_number" }
      ],
      "default": "2"
    },
    {
      "type": "header",
      "content": "t:sections.bestsellers_tabs.settings.header_badge"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "t:sections.bestsellers_tabs.settings.badge_text.label",
      "default": "Bestseller"
    },
    {
      "type": "text",
      "id": "badge_tag",
      "label": "t:sections.bestsellers_tabs.settings.badge_tag.label",
      "info": "t:sections.bestsellers_tabs.settings.badge_tag.info"
    },
    {
      "type": "color",
      "id": "badge_color",
      "label": "t:sections.bestsellers_tabs.settings.badge_color.label",
      "default": "#bd3702"
    },
    {
      "type": "header",
      "content": "t:content.buttons"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.bestsellers_tabs.settings.button_label.label",
      "default": "+ Add to Box"
    },
    {
      "type": "header",
      "content": "t:content.carousel_navigation"
    },
    {
      "type": "select",
      "id": "icons_style",
      "label": "t:settings.icon",
      "options": [
        { "value": "chevron", "label": "t:options.chevrons" },
        { "value": "none", "label": "t:options.none" }
      ],
      "default": "chevron"
    },
    {
      "type": "select",
      "id": "icons_shape",
      "label": "t:settings.icon_background",
      "options": [
        { "value": "none", "label": "t:options.none" },
        { "value": "circle", "label": "t:options.circle" },
        { "value": "square", "label": "t:options.square" }
      ],
      "default": "none",
      "visible_if": "{{ section.settings.icons_style != 'none' }}"
    },
    {
      "type": "header",
      "content": "t:content.section_layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        { "value": "page-width", "label": "t:options.page" },
        { "value": "full-width", "label": "t:options.full" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 64
    },
