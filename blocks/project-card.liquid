{% doc %}
  Project Card Block

  Renders a card with a square image and title/subtitle displayed below the
  image. Suitable for portfolio/project grids. Optionally links to a URL.

  @example
  Used as a block inside section.liquid:
  {% content_for 'block', type: 'project-card', id: 'project-1' %}
{% enddoc %}

{%- liquid
  assign block_settings = block.settings
  assign has_link = false
  if block_settings.link != blank
    assign has_link = true
  endif
-%}

<div
  class="project-card"
  {{ block.shopify_attributes }}
>
  <div
    class="project-card__media"
    style="--project-card-ratio: {{ block_settings.image_ratio }};"
  >
    {%- if block_settings.image != blank -%}
      {{
        block_settings.image
        | image_url: width: 1200
        | image_tag:
          widths: '375, 550, 750, 1100',
          sizes: '(min-width: 992px) 33vw, (min-width: 576px) 50vw, 100vw',
          class: 'project-card__image',
          alt: block_settings.title | escape
      }}
    {%- else -%}
      <div class="project-card__placeholder" aria-hidden="true">
        {{ 'image' | placeholder_svg_tag: 'project-card__placeholder-svg' }}
      </div>
    {%- endif -%}
    {%- if has_link -%}
      <a
        href="{{ block_settings.link }}"
        class="project-card__overlay-link"
        aria-label="{{ block_settings.title | escape }}"
        tabindex="-1"
        aria-hidden="true"
      ></a>
    {%- endif -%}
  </div>

  {%- if block_settings.title != blank or block_settings.subtitle != blank -%}
    <div class="project-card__info">
      {%- if block_settings.title != blank -%}
        <h3 class="project-card__title">
          {%- if has_link -%}
            <a href="{{ block_settings.link }}" class="project-card__title-link">
              {{- block_settings.title | escape -}}
            </a>
          {%- else -%}
            {{- block_settings.title | escape -}}
          {%- endif -%}
        </h3>
      {%- endif -%}
      {%- if block_settings.subtitle != blank -%}
        <p class="project-card__subtitle">{{ block_settings.subtitle | escape }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}
</div>

{% stylesheet %}
  .project-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .project-card__media {
    --project-card-ratio: 1 / 1;

    position: relative;
    overflow: hidden;
    border-radius: var(--style-border-radius-md, 4px);
    aspect-ratio: var(--project-card-ratio);
    background: rgb(var(--color-foreground-rgb) / 0.05);
  }

  .project-card__overlay-link {
    display: block;
    position: absolute;
    inset: 0;
    z-index: var(--layer-flat);
  }

  .project-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--animation-speed-slow) var(--animation-easing);
  }

  .project-card:hover .project-card__image {
    transform: scale(1.04);
  }

  .project-card__placeholder {
    width: 100%;
    height: 100%;
    background: rgb(var(--color-foreground-rgb) / 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .project-card__placeholder-svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .project-card__info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .project-card__title {
    font-family: var(--font-body--family);
    font-size: var(--font-size--lg, 1.125rem);
    font-weight: 400;
    color: rgb(var(--color-foreground-rgb));
    margin: 0;
    line-height: 1.3;
  }

  .project-card__title-link {
    color: inherit;
    text-decoration: none;
  }

  .project-card__title-link:hover {
    opacity: 0.75;
  }

  .project-card__subtitle {
    font-size: var(--font-size--xs, 0.75rem);
    color: rgb(var(--color-foreground-rgb) / 0.55);
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card__image {
      transition: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.project_card",
  "tag": null,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:settings.image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "t:settings.project_card.title"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "t:settings.project_card.subtitle"
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:settings.project_card.link"
    },
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "t:settings.image_ratio",
      "options": [
        {
          "value": "1 / 1",
          "label": "t:options.square"
        },
        {
          "value": "3 / 4",
          "label": "t:options.portrait"
        },
        {
          "value": "4 / 3",
          "label": "t:options.landscape"
        },
        {
          "value": "16 / 9",
          "label": "t:options.widescreen"
        }
      ],
      "default": "1 / 1"
    }
  ],
  "presets": [
    {
      "name": "t:names.project_card",
      "category": "t:categories.text"
    }
  ]
}
{% endschema %}
