{% doc %}
  Project Card Block

  Renders a card with an image and an overlaid title, suitable for
  portfolio / project grids. Optionally links to an arbitrary URL.

  @example
  Used as a block inside section.liquid:
  {% content_for 'block', type: 'project-card', id: 'project-1' %}
{% enddoc %}

{%- liquid
  assign block_settings = block.settings
  assign has_link = false
  if block_settings.link != blank
    assign has_link = true
  endif
-%}

<div
  class="project-card"
  style="
    --project-card-ratio: {{ block_settings.image_ratio }};
    --project-card-overlay-opacity: {{ block_settings.overlay_opacity | divided_by: 100.0 }};
  "
  {{ block.shopify_attributes }}
>
  {%- if has_link -%}
    <a href="{{ block_settings.link }}" class="project-card__link" aria-label="{{ block_settings.title | escape }}">
  {%- endif -%}

    <div class="project-card__media">
      {%- if block_settings.image != blank -%}
        {{
          block_settings.image
          | image_url: width: 1200
          | image_tag:
            widths: '375, 550, 750, 1100',
            sizes: '(min-width: 992px) 33vw, (min-width: 576px) 50vw, 100vw',
            class: 'project-card__image',
            alt: block_settings.title | escape
        }}
      {%- else -%}
        <div class="project-card__placeholder" aria-hidden="true">
          {{ 'image' | placeholder_svg_tag: 'project-card__placeholder-svg' }}
        </div>
      {%- endif -%}
    </div>

    <div class="project-card__overlay" aria-hidden="true"></div>

    {%- if block_settings.title != blank -%}
      <div class="project-card__content">
        <h3 class="project-card__title">
          {{ block_settings.title | escape }}
        </h3>
      </div>
    {%- endif -%}

  {%- if has_link -%}
    </a>
  {%- endif -%}
</div>

{% stylesheet %}
  .project-card {
    --project-card-ratio: 3 / 4;
    --project-card-overlay-opacity: 0.35;

    position: relative;
    overflow: hidden;
    border-radius: var(--style-border-radius-md);
    aspect-ratio: var(--project-card-ratio);
  }

  .project-card__link {
    display: block;
    position: absolute;
    inset: 0;
    text-decoration: none;
    color: inherit;
    z-index: var(--layer-flat);
  }

  .project-card__media {
    position: absolute;
    inset: 0;
  }

  .project-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--animation-speed-slow) var(--animation-easing);
  }

  .project-card:hover .project-card__image {
    transform: scale(1.04);
  }

  .project-card__placeholder {
    width: 100%;
    height: 100%;
    background: rgb(var(--color-foreground-rgb) / var(--opacity-5-15));
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .project-card__placeholder-svg {
    width: 50%;
    height: 50%;
    opacity: 0.4;
  }

  .project-card__overlay {
    position: absolute;
    inset: 0;
    background: rgb(0 0 0 / var(--project-card-overlay-opacity));
    pointer-events: none;
    transition: opacity var(--animation-speed-slow) var(--animation-easing);
  }

  .project-card:hover .project-card__overlay {
    opacity: 0.8;
  }

  .project-card__content {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    padding: var(--padding-lg);
    pointer-events: none;
    z-index: var(--layer-flat);
  }

  .project-card__title {
    color: #fff;
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: var(--font-size--lg);
    line-height: var(--line-height--heading-normal);
    margin: 0;
    text-shadow: 0 1px 3px rgb(0 0 0 / 0.3);
  }

  @media screen and (min-width: 576px) {
    .project-card__title {
      font-size: var(--font-size--xl);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card__image {
      transition: none;
    }
    .project-card__overlay {
      transition: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.project_card",
  "tag": null,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:settings.image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "t:settings.project_card.title"
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:settings.project_card.link"
    },
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "t:settings.image_ratio",
      "options": [
        {
          "value": "1 / 1",
          "label": "t:options.square"
        },
        {
          "value": "3 / 4",
          "label": "t:options.portrait"
        },
        {
          "value": "4 / 3",
          "label": "t:options.landscape"
        },
        {
          "value": "16 / 9",
          "label": "t:options.widescreen"
        }
      ],
      "default": "3 / 4"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "t:settings.project_card.overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 35
    }
  ],
  "presets": [
    {
      "name": "t:names.project_card",
      "category": "t:categories.text"
    }
  ]
}
{% endschema %}
